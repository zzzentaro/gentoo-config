#!/bin/sh
set -eu
. "$HOME/.local/lib/zxy" || {
    printf ' !! zxy is missing\n'
    exit 1
}
readonly _CMD=portage
zxy_need_command sudo emerge

# Sync
portage_sync() {
    sudo rm -f /var/db/repos/gentoo/metadata/timestamp.x && sudo emerge-webrsync
    sudo emaint sync --all
}

# Rebuild
portage_rebuild() {
    sudo emerge @preserved-rebuild @module-rebuild
    zxy_is_cmd revdep-rebuild && sudo revdep-rebuild
}

# Update
portage_update() {
    sudo emerge --ask --update --newuse --deep --with-bdeps=y --keep-going @world
}

# Fix
portage_fix() {
    for cmd in etc-update env-update dispatch-conf; do
        zxy_log "$cmd"
        sudo "$cmd"
    done
    sudo emaint --fix all
}

# Clean
portage_clean() {
    sudo emerge --ask --depclean
    sudo eclean-dist --deep
    sudo eclean-pkg --deep
    sudo eclean-kernel
}

# Find
search() {
    __package="$1"
    [ -z "$__package" ] && log 'No package to search' 1

    zxy_log "Entry(s) for ${1:-}"
    if zxy_is_cmd eix; then
        eix "$1"
    else
        emerge --search "$1"
    fi

}
query() {
    __package="$1"
    [ -z "$__package" ] && log 'No package to query' 1

    if zxy_is_cmd equery; then
        zxy_log "Flag(s) for $1"
        equery u "$1"
    fi
}
portage_find() {
    for package in "$@"; do
        search "$package"
        query "$package"
    done
}

# Usedesc
portage_usedesc() {
    _USEDESC_FILE='/var/db/repos/gentoo/profiles/use.desc'

    __USEDESC="${1:-}"
    if [ -z "$__USEDESC" ]; then
        cat "$_USEDESC_FILE"
    else
        for flag in "$@"; do
            grep "$flag" /var/db/repos/gentoo/profiles/use.desc
        done
    fi
}

# Kernel
portage_kernel() {
    if [ -z "${1:-}" ]; then
        zxy_log "Kernel(s) inside /usr/src/"
        ls -Ahl /usr/src
        echo
    else
        sudo eselect kernel set "$1"
    fi
    eselect kernel list
}

# Repo
portage_repo() {
    eselect repository list -i
}

# Merge
portage_merge() {
    [ "$#" -lt 1 ] && log 'Nothing to merge' 1

    sudo emerge --ask "$@"
}

portage_unmerge() {
    [ "$#" -lt 1 ] && log 'Nothing to unmerge' 1

    sudo emerge --ask --unmerge "$@"
}

# Edit
editor() {
    __text="$1"
    [ -z "$__text" ] && log 'No text to edit' 1

    EDITOR="${EDITOR:-nano}"
    if [ -w "$__text" ] || [ -L "$__text" ]; then
        $EDITOR "$__text"
    else
        sudoedit "$__text"
    fi
}
portage_edit() {
    __portage='/etc/portage'
    [ ! -d "$__portage" ] && log 'Portage directory missing' 1

    __make_conf="${__portage:?}/make.conf"
    __dir="${1:-}"
    if [ -z "$__dir" ]; then
        editor "$__make_conf"
        return
    fi

    case "$__dir" in
    unmask | umask | um | accept | acpt)
        __dir=package.accept_keywords
        ;;
    mask | m | hide)
        __dir=package.mask
        ;;
    use | u)
        __dir=package.use
        ;;
    s)
        __dir=sets
        ;;
    make.conf | make | mk)
        portage_edit
        ;;
    esac
    [ ! -d "$__portage/$__dir" ] && zxy_log "Directory $__portage/$__dir does not exist" 1

    __file="${2:-}"
    if [ -z "$__file" ]; then
        ls -AhLl -- "$__portage/$__dir"
        return
    fi

    editor "$__portage/$__dir/$__file"
}

portage_help() {
    cat <<EOF
Usage:
    $_CMD < sync | rebuild | update | clean | repo >
    $_CMD [ search | usedesc | kernel ] [ ... ]
    $_CMD [ merge | unmerge | edit ] [ ... ]"
EOF
    return 1
}
readonly _SUB_CMD="${1:-help}"
case "$_SUB_CMD" in
sync | sy) portage_sync ;;
rebuild | reb | rb) portage_rebuild ;;
update | up) portage_update ;;
fix | x) portage_fix ;;
clean | cl) portage_clean ;;
repo | r) portage_clean ;;
# accept args
find | f)
    shift
    portage_find "$@"
    ;;
usedesc | use | u)
    shift
    portage_usedesc "$@"
    ;;
kernel | k)
    shift
    portage_kernel "$@"
    ;;
merge | m | +)
    shift
    portage_merge "$@"
    ;;
unmerge | um | -)
    shift
    portage_unmerge "$@"
    ;;
edit | e)
    shift
    portage_edit "$@"
    ;;
*) portage_help ;;
esac
