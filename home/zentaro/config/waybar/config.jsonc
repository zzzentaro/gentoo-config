    "modules-right": [
        "tray",
        "pulseaudio",
        "backlight",
        "battery",
        "network",
        "power-profiles-daemon"
    ],
    "tray": {
        "show-passive-items": true,
        "icon-size": 20,
        "spacing": 8
    },
    "pulseaudio": {
        "format": "{volume}%{icon}",
        "format-bluetooth": "{volume}%{icon}οäî",
        "format-muted": "νΜ®",
