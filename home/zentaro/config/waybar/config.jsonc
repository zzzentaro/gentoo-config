{
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "height": 36,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window",
        "hyprland/submap"
    ],
    "hyprland/workspaces": {
        "all-outputs": false,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "8": [],
            "9": []
        },
        "format": "{icon}",
        "format-icons": {
            "1": "νüΠ",
            "2": "ο²§",
            "3": "ν€²",
            "4": "4",
            "5": "5",
            "6": "6",
            "7": "7",
