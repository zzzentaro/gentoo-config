    "modules-center": [
        "clock"
    ],
    "clock": {
        "format": "{:%I:%M %p}",
        "tooltip-format": "{:%A, %d %B %Y}",
        "on-click": "bash menu"
    },
    "modules-right": [
        "tray",
        "pulseaudio",
        "backlight",
        "battery",
        "network",
        "power-profiles-daemon"
    ],
    "tray": {
        "show-passive-items": true,
        "icon-size": 20,
        "spacing": 8
    },
    "pulseaudio": {
        "format": "{volume}%{icon}",
        "format-bluetooth": "{volume}%{icon}´èö",
        "format-muted": "¯╗¿",
        "format-icons": {
            "default": [
                "´Çğ",
                "´Ç¿"
            ],
            "headphone": "´ÇÑ",
            "headset": "¯╣Ö",
            "phone": "´éò",
            "phone-muted": "¯┤ù",
            "hands-free": "´èğ",
            "car": "´å╣",
            "portable": "¯¥®"
        },
        "scroll-step": 5,
        "on-click": "pavucontrol"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}%{icon}",
        "format-icons": [
            "¾░âŞ",
            "¾░âş",
            "¾░âá"
        ]
    },
    "battery": {
