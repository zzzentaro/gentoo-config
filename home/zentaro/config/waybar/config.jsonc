    "modules-center": [
        "clock"
    ],
    "clock": {
        "format": "{:%I:%M %p}",
        "tooltip-format": "{:%A, %d %B %Y}",
        "on-click": "bash menu"
    },
    "network": {
        "format-wifi": "σΑ•©",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) σΑ•©",
        "format-ethernet": "νΫ³",
