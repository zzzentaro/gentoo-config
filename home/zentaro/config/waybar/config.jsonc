    "network": {
        "format-wifi": "¾░ñ¿",
        "tooltip-format-wifi": "{signalStrength}% {essid} ¾░ñ¿",
        "format-ethernet": "¯¢ä",
        "tooltip-format-ethernet": "{ifname} ¯¢ä",
        "format-disconnected": "¾░ú¢",
        "tooltip-format-disconnected": "Disconnected ¾░ú¢",
        "on-click": "alacritty -e sleep 1; nmtui"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
