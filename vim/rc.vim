set directory=~/.vim/swap//
set undodir=~/.vim/undo//
set undofile
set backupdir=~/.vim/backup//
set backup

set tabstop=8
set shiftwidth=8
set softtabstop=8
set noexpandtab

set incsearch
set ignorecase
set smartcase
nnoremap <Esc> :nohlsearch<CR>

set showcmd
set scrolloff=8
set wrap
syntax on

set backspace=indent,eol,start
set wildmenu
set laststatus=1
set encoding=utf-8
