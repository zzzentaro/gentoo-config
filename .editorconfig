root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
max_line_length = 80
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{c,h}]
indent_style = tab
indent_size = 8

[{*.{sh,bash},.bash_profile,.bashrc,.bash_logout}]
indent_style = tab
shell_variant = posix
binary_next_line = true
keep_padding = true
function_next_line = true

[*.{html,yaml}]
indent_size = 2
